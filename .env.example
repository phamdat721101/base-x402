# Server — your receiving wallet address
WALLET_ADDRESS=0xYourReceivingAddress

# Client — private key for signing payments (must have testnet USDC)
# Used by all clients: buyer, agent, bazaar:discover, bazaar:agent, mcp
PRIVATE_KEY=0xYourClientPrivateKey

# Network toggle: "testnet" (Base Sepolia) or "mainnet" (Base)
NETWORK=testnet

# Bazaar facilitator URL (default: x402.org testnet facilitator)
# FACILITATOR_URL=https://x402.org/facilitator

# Only needed for mainnet (Coinbase CDP facilitator)
# CDP_API_KEY_ID=your-cdp-key-id
# CDP_API_KEY_SECRET=your-cdp-key-secret
